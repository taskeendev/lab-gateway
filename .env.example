# พอร์ตที่ Kong เปิดออกนอก: proxy = ประตูหน้าระบบ / admin = จัดการ
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

# ปลายทางของแต่ละ service (dev: รันบนเครื่อง Kong เข้าผ่าน host.docker.internal)
AUTH_UPSTREAM=http://host.docker.internal:8081
PRESENCE_UPSTREAM=http://host.docker.internal:8082
FEED_UPSTREAM=http://host.docker.internal:8083
CONTACT_UPSTREAM=http://host.docker.internal:8084

# ต้องตรงกับ JWT_SECRET ของ auth-service เป๊ะ (Kong verify ลายเซ็นด้วยตัวนี้)
JWT_SECRET=must-match-auth-service-secret

# CORS: ใส่เป็น inline array (dev = vite, prod = เว็บบน Vercel)
CORS_ORIGINS="http://localhost:5173","https://lab-web-taupe.vercel.app"
# เพดานยิงต่อ IP ต่อนาที (ทั่วไป / เส้น auth เข้มกว่า)
RATE_LIMIT_PER_MIN=100
AUTH_RATE_LIMIT_PER_MIN=20
